# Copy to .env and fill in. Never commit your real .env.

# Anthropic API key — enables the "AI Suggest" feature (Claude vision).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Apps Script Web App URL that appends waitlist signups to your Sheet.
# See README.md → "Waitlist (Google Sheets)" for the 2-minute setup.
GOOGLE_SHEETS_WEBHOOK_URL=

# Port the server listens on (optional).
PORT=3000
